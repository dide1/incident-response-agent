# Required
ANTHROPIC_API_KEY=sk-ant-...

# Optional — Slack Incoming Webhook URL for incident briefs and postmortems
# If unset, briefs are logged to stdout instead of posted
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# Optional — real GitHub repos the agent can investigate (comma-separated owner/repo).
# The repo short name doubles as the service name in alerts.
GITHUB_REPOS=
# Optional — PAT for private repos / higher rate limits (read-only scope is enough)
GITHUB_TOKEN=
# Optional — HMAC secret for verifying GitHub webhook deliveries to /webhook/github
GITHUB_WEBHOOK_SECRET=

# Fault mode vars — managed by inject_fault.sh and heal.sh, do not edit manually
ORDER_FAULT_MODE=false
PAYMENT_FAULT_MODE=false
API_FAULT_MODE=false
